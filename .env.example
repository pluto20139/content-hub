# Supabase
SUPABASE_URL=              # Supabase 项目 URL
SUPABASE_ANON_KEY=         # 匿名密钥
SUPABASE_SERVICE_ROLE_KEY= # 服务角色密钥（切勿泄露）

# 前端（Vite 编译期加载）
VITE_SUPABASE_URL=         # 与上方 SUPABASE_URL 一致
VITE_SUPABASE_ANON_KEY=    # 与上方 SUPABASE_ANON_KEY 一致
VITE_SITE_URL=             # 站点访问地址，例如 https://mpchub.top

# YouTube
YOUTUBE_API_KEY=           # YouTube Data API v3 密钥

# RSSHub & Proxy Configurations
RSSHUB_URL=                   # RSSHub 自建或公共服务地址，如 https://rsshub.app
DOUYIN_PROXY_LIST=            # 抖音抓取代理池列表，以逗号分隔，格式 http://user:pass@host:port
XIAOHONGSHU_PROXY_LIST=       # 小红书抓取代理池列表，以逗号分隔
ZHIHU_PROXY_LIST=             # 知乎抓取代理池列表，以逗号分隔
EDGE_PROXY_LIST=              # Edge Function 代理列表
IMAGE_PROXY_ENABLED=true      # 启用 B站 封面图代理（可选）

# 告警
WECOM_WEBHOOK_URL=         # 企业微信 Webhook URL（可选）

# Dify Workflow
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=              # Dify Workflow API Key

