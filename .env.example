# Supabase
SUPABASE_URL=              # Supabase 项目 URL
SUPABASE_ANON_KEY=         # 匿名密钥（H5/Admin 前端使用）
SUPABASE_SERVICE_ROLE_KEY= # 服务角色密钥（Cron 脚本使用，切勿泄露）

# YouTube
YOUTUBE_API_KEY=           # YouTube Data API v3 密钥（GitHub Secrets + Supabase Secrets 双配置）

# B站代理（GitHub Actions 跨境访问 B站 API 时配置）
BILIBILI_PROXY_URL=        # 指向部署的 bilibili-fetch Edge Function URL
CRON_API_KEY=              # bilibili-fetch 鉴权密钥（与 Edge Function env 一致）

# RSSHub（Phase 2 启用知乎时配置）
# RSSHUB_URL=
# RSSHUB_API_KEY=

# 告警
WECOM_WEBHOOK_URL=         # 企业微信 Webhook URL（可选，未配置则仅记录日志）
